# Get both from platform.cognee.ai/api-keys — API Base URL is tenant-specific,
# e.g. https://tenant-<your-tenant-id>.aws.cognee.ai (not api.cognee.ai)
COGNEE_API_KEY=your_cognee_cloud_api_key_here
COGNEE_BASE_URL=https://tenant-your-tenant-id.aws.cognee.ai

# LLM_PROVIDER selects which backend generate_response() uses: "gemini" or "openai"
LLM_PROVIDER=gemini

GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI-compatible provider (e.g. AWS Bedrock Mantle gateway, GLM-5, etc.)
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_BASE_URL=https://bedrock-mantle.ap-south-1.api.aws/v1
OPENAI_MODEL=zai.glm-5

# Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID (Web application)
# Must match VITE_GOOGLE_CLIENT_ID used by the frontend.
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Signs the session cookie (itsdangerous). Any long random string; rotate to invalidate all sessions.
SESSION_SECRET=a_long_random_secret_string_min_32_chars

ENVIRONMENT=development
